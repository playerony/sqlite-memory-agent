{
	"name": "sqlite-memory-agent",
	"version": "1.0.0",
	"type": "module",
	"bin": {
		"memory": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsx watch --env-file=.env src/index.ts",
		"start": "tsx --env-file=.env src/index.ts",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"typecheck": "tsc --noEmit",
		"eval:sqlite-tools": "npx lmnr eval evals/sqlite-tools.eval.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.14",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^2.0.0",
		"@lmnr-ai/lmnr": "^0.7.9",
		"ai": "^5.0.102",
		"dotenv": "^17.3.1",
		"ink": "^6.8.0",
		"ink-spinner": "^5.0.0",
		"react": "^19.2.4",
		"zod": "^4.3.6"
	}
}
